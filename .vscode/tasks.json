{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "xcodebuild: BeFree (iOS Simulator)",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-project",
        "BeFree.xcodeproj",
        "-scheme",
        "BeFree",
        "-destination",
        "generic/platform=iOS Simulator",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      },
      "problemMatcher": []
    }
  ]
}
